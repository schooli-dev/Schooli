NODE_ENV=development
PORT=5000
PUBLIC_API_BASE_URL=http://localhost:5000/api

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:4200

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_DEFAULT_HOST_EMAIL=
ZOOM_AUTO_CREATE_MEETINGS=true
ZOOM_MEETING_WAITING_ROOM=true
ZOOM_MEETING_JOIN_BEFORE_HOST=false
ZOOM_MEETING_PASSWORD_REQUIRED=true
ZOOM_MEETING_AUTO_RECORDING=none
ZOOM_MEETING_SDK_KEY=
ZOOM_MEETING_SDK_SECRET=
